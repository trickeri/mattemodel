# Copy to config.env and edit for machine-specific overrides. All optional.
# mattemodel.sh sources this if present.

# Where to bind the local HTTP server.
#MM_HOST=127.0.0.1
#MM_PORT=48460

# Backend is normally read from build/backend.txt (written by build.sh). Override
# only if you know what you're doing: cuda (ONNX Runtime) or vulkan (ncnn).
#MM_BACKEND=cuda

# Model override. Default is picked from the backend:
#   cuda   → models/rvm_resnet50_fp16.onnx
#   vulkan → models/rvm_resnet50   (loads rvm_resnet50.ncnn.{param,bin})
#MM_MODEL=$HOME/programming/mattemodel/models/rvm_resnet50_fp16.onnx

#MM_SERVER_BIN=$HOME/programming/mattemodel/build/mattemodel-server
